{
  "manifest_version": 3,
  "name": "Dino Rush",
  "version": "1.0.2",
  "description": "An enhanced Chrome Dino runner game with skins, coins, and progression.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/sounds/*.mp3"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}